# ===================================
# A股自选股智能分析系统 - 环境变量配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================

# 自选股列表（逗号分隔）
STOCK_LIST=600519,300750,002594

# ===================================
# AI 模型配置
# ===================================
# DeepSeek API Key（在 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 如果不填 DEEPSEEK_API_KEY，也可以填 Gemini（免费）：
# GEMINI_API_KEY=your_gemini_key_here

# ===================================
# 推送渠道：飞书
# ===================================
# 在飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_url_here
# 如果开启了签名验证才需要填
# FEISHU_WEBHOOK_SECRET=your_secret_here

# ===================================
# 数据源配置（可选）
# ===================================
# TUSHARE_TOKEN=
# TICKFLOW_API_KEY=
# ANSPIRE_API_KEYS=
# TAVILY_API_KEYS=
# BOCHA_API_KEYS=
# MINIMAX_API_KEYS=

# ===================================
# 高级配置
# ===================================
AGENT_ORCHESTRATOR_MODE=full
ENABLE_REALTIME_TECHNICAL_INDICATORS=true
ENABLE_REALTIME_QUOTE=true
ENABLE_CHIP_DISTRIBUTION=true
NEWS_MAX_AGE_DAYS=7
NEWS_STRATEGY_PROFILE=medium
LLM_CHANNELS=deepseek
LITELLM_FALLBACK_MODELS=deepseek/deepseek-v4-flash,deepseek/deepseek-v4-pro
VISION_MODEL=deepseek/deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_DEEPSEEK_PROTOCOL=deepseek
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK_ENABLED=true
LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
AGENT_RISK_OVERRIDE=true
